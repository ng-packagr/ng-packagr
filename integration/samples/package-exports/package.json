{
  "name": "@sample/package-exports",
  "description": "A sample library using package.json subpath exports",
  "version": "1.0.0-pre.0",
  "private": true,
  "repository": "https://github.com/ng-packagr/ng-packagr.git",
  "peerDependencies": {
    "@angular/core": "^4.1.2",
    "@angular/common": "^4.1.2",
    "@angular/common": "^4.1.3",
    "@angular/core": "^4.1.3",
    "rxjs": "^5.0.1"
  },
  "exports": {
    ".": "public_api.js",
    "./package.json": "./package.json",
    "./sub": {
      "foo": "./sub/foo.js",
      "default": "./sub/sub.js"
    }
  }
}
